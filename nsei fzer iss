<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Surpresa para Você</title>
    <style>
        body { 
            text-align: center; 
            font-family: Arial, sans-serif; 
            margin-top: 50px; 
            background-color: #f4f4f4;
        }
        button { 
            font-size: 18px; 
            margin: 10px; 
            padding: 10px 20px; 
            cursor: pointer; 
            border: none; 
            background-color: #007BFF; 
            color: white; 
            border-radius: 5px;
        }
        button:hover {
            background-color: #0056b3;
        }
        #mensagem {
            font-size: 20px;
            margin-top: 20px;
            color: #333;
        }
    </style>
</head>
<body>
    <h2>Amor, adivinha o que eu fiz? Quer saber?</h2>
    <button onclick="mostrarMensagem()">Quero</button>

    <p id="mensagem"></p>

    <script>
        function mostrarMensagem() {
            document.getElementById("mensagem").innerHTML = 
            "Aprendi a fazer isso só pra dizer que te amo na sua linguagem de garoto de propaganda! ❤️";
        }
    </script>
</body>
</html>
